{
  "name": "audistill",
  "version": "0.1.0",
  "description": "Distill knowledge from every conversation — local-first for macOS",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Audistill",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "pretest": "pnpm rebuild better-sqlite3",
    "test": "vitest run",
    "posttest": "electron-rebuild -f -w better-sqlite3 --build-from-source",
    "postinstall": "rm -rf node_modules/better-sqlite3/build && electron-rebuild -f -w better-sqlite3 --build-from-source",
    "build:mac": "pnpm run build && electron-builder --mac"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.10.0",
    "ffmpeg-static": "^5.3.0",
    "onnxruntime-node": "^1.26.0",
    "react-markdown": "^10.1.0",
    "zustand": "^5.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "ffmpeg-static",
      "onnxruntime-node"
    ]
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.4",
    "@tanstack/react-virtual": "^3.14.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ffmpeg-static": "^5.1.0",
    "@types/node": "^22.12.11",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "lucide-react": "^1.17.0",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  }
}
